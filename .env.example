# ── FraudShield AI — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in production values

# Backend
PORT=8000
HOST=0.0.0.0

# CORS — allowed frontend origin (use * for dev, specific URL for production)
FRONTEND_ORIGIN=*

# Model paths (defaults work out of the box)
# MODEL_PATH=backend/model/best_model.pkl
# SCALER_PATH=backend/model/scaler.pkl

# Workers (production)
WEB_CONCURRENCY=2

# Log level
LOG_LEVEL=info
